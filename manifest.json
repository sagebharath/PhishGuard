{
  "manifest_version": 3,
  "name": "PhishGuard",
  "version": "1.0",
  "description": "Advanced phishing detection browser extension",

  "permissions": ["tabs", "storage", "webNavigation", "activeTab"],

  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishGuard"
  }
}